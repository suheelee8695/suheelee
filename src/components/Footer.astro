---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-cta">
      <h2 class="cta-title">Let's make<br/>something <em>fun.</em></h2>
      <a class="btn cta-btn" href="mailto:suheelee8695@gmail.com?subject=Let's%20connect!">
        Say hi → suheelee8695@gmail.com
      </a>
    </div>

    <div class="footer-meta">
      <div class="footer-mark">
        <span class="brand-mark">SL</span>
        <p>UX/UI Designer<br/>based in Berlin</p>
      </div>
      <ul class="footer-links">
        <li><a href="https://www.instagram.com/illustrationbysuhee/" target="_blank" rel="noopener">Instagram ↗</a></li>
        <li><a href="https://www.linkedin.com/in/suhee-lee/" target="_blank" rel="noopener">LinkedIn ↗</a></li>
        <li><a href="https://www.behance.net/suheelee8695" target="_blank" rel="noopener">Behance ↗</a></li>
      </ul>
      <p class="footer-fine">© {year} Suhee Lee. Designed &amp; coded with care.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--bg);
    margin-top: var(--s-10);
    padding: var(--s-9) 0 var(--s-6);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--s-9);
  }
  .footer-cta {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    align-items: flex-start;
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--bg);
    margin: 0;
  }
  .cta-title em {
    font-style: italic;
    color: var(--accent-lime);
  }
  .cta-btn {
    background: var(--accent-orange);
    color: var(--bg);
  }
  .cta-btn:hover { background: var(--accent-lime); color: var(--ink); }

  .footer-meta {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--s-5);
    align-items: end;
    border-top: 1px solid color-mix(in srgb, var(--bg) 15%, transparent);
    padding-top: var(--s-6);
  }
  .footer-mark { display: flex; align-items: center; gap: var(--s-3); }
  .footer-mark p { margin: 0; font-size: 0.875rem; opacity: 0.7; }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 700;
  }
  .footer-links {
    display: flex;
    gap: var(--s-4);
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: center;
  }
  .footer-links a {
    font-weight: 500;
    transition: color 0.2s var(--ease);
  }
  .footer-links a:hover { color: var(--accent-lime); }
  .footer-fine {
    font-size: 0.8125rem;
    opacity: 0.5;
    margin: 0;
    text-align: right;
  }

  @media (max-width: 720px) {
    .footer-meta { grid-template-columns: 1fr; gap: var(--s-5); }
    .footer-links { justify-content: flex-start; flex-wrap: wrap; }
    .footer-fine { text-align: left; }
  }
</style>
