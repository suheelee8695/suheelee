---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('work', ({ data }) => !data.draft);
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const featured = sorted.filter(e => e.data.featured);
const more = sorted.filter(e => !e.data.featured);
---
<Base title="Suhee Lee · Senior Product Designer" current="home">

  <!-- HERO -->
  <section class="hero">
    <div class="blob blob-a" style="background:#FF5A1F;"></div>
    <div class="blob blob-b" style="background:#D4FF3A;"></div>
    <div class="blob blob-c" style="background:#FF6FA8;"></div>

    <div class="hero-inner container">
      <p class="eyebrow"><span class="dot">●</span> Open to full-time Senior Product Designer roles · AI/UX · Berlin / remote EU</p>
      <h1 class="hero-title">
        Hello, <em>you.</em><br/>
        I'm Suhee, a Senior Product Designer<br/>
        designing AI features and shipping them.
      </h1>
      <p class="hero-sub">
        I design AI features for enterprise B2B — the kind where the AI has to earn trust before it gets authority.
        At Quentic, I authored the AI design guidelines before the features shipped,
        designed 5 Whys and SDS Extract, and built the design→dev workflow my team ships with today.
        7+ years across enterprise and B2B SaaS. Berlin-based.
      </p>
      <div class="hero-cta">
        <a href="#work" class="btn">See selected work ↓</a>
        <a href="/about" class="btn btn-ghost">About me</a>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
      <span>Design systems <span class="dot">●</span></span>
      <span>AI/UX <span class="dot">●</span></span>
      <span>Design engineering <span class="dot">●</span></span>
      <span>Product design <span class="dot">●</span></span>
      <span>Mobile + web <span class="dot">●</span></span>
      <span>Brand identity <span class="dot">●</span></span>
      <span>Illustration <span class="dot">●</span></span>
      <span>Design systems <span class="dot">●</span></span>
      <span>AI/UX <span class="dot">●</span></span>
      <span>Design engineering <span class="dot">●</span></span>
      <span>Product design <span class="dot">●</span></span>
      <span>Mobile + web <span class="dot">●</span></span>
      <span>Brand identity <span class="dot">●</span></span>
      <span>Illustration <span class="dot">●</span></span>
    </div>
  </div>

  <!-- FEATURED WORK -->
  <section id="work" class="work">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow eyebrow-dark">01 · Selected case studies</p>
        <h2 class="section-title">Recent <em>work.</em></h2>
      </header>

      <div class="featured-grid">
        {featured.map((entry, i) => (
          <a href={`/work/${entry.id}`} class={`feature-card accent-${entry.data.accent}`}>
            <span class="feature-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="feature-image">
              <img src={entry.data.tile} alt={entry.data.title} loading="lazy" />
            </div>
            <div class="feature-text">
              <div class="feature-tags">
                {entry.data.tags.slice(0, 3).map(t => <span class="pill">{t}</span>)}
              </div>
              <h3 class="feature-title">{entry.data.title}</h3>
              <p class="feature-summary">{entry.data.summary}</p>
              <span class="feature-cta">
                {entry.data.locked ? '🔒 Unlock case study →' : 'View case study →'}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE PROJECTS -->
  <section class="more-work">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow eyebrow-dark">02 · More work</p>
        <h2 class="section-title">Other <em>projects.</em></h2>
      </header>
      <div class="more-grid">
        {more.map(entry => (
          <a href={`/work/${entry.id}`} class={`mini-card accent-${entry.data.accent}`}>
            <div class="mini-image">
              <img src={entry.data.tile} alt={entry.data.title} loading="lazy" />
            </div>
            <h4 class="mini-title">{entry.data.title}</h4>
            <p class="mini-tagline">{entry.data.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ALSO BUILDING -->
  <section class="also-building">
    <div class="container">
      <header class="section-head section-head-center">
        <p class="eyebrow eyebrow-dark">03 · Personal venture</p>
        <h2 class="section-title">Also <em>building.</em></h2>
        <p class="also-sub">Beyond product design, I run a small business in Berlin.</p>
      </header>

      <a href="https://einharu.com" target="_blank" rel="noopener" class="venture-card">
        <div class="venture-image">
          <img src="/images/einharu-tile.png" alt="einHaru Collective" loading="lazy" />
        </div>
        <div class="venture-text">
          <h3 class="venture-title">einHaru Collective</h3>
          <p class="venture-desc">
            A Berlin-based boutique curating minimalist Korean fashion designers.
            Bilingual EN/DE, EU-wide shipping. Built and run by me.
          </p>
          <span class="venture-cta">Visit live ↗</span>
        </div>
      </a>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    padding: var(--s-9) 0 var(--s-8);
  }
  .blob-a { width: 480px; height: 480px; top: -120px; left: -160px; }
  .blob-b { width: 360px; height: 360px; bottom: -120px; right: -80px; opacity: 0.45; }
  .blob-c { width: 280px; height: 280px; top: 30%; right: -120px; opacity: 0.4; }

  .hero-inner { position: relative; z-index: 1; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    background: var(--ink);
    color: var(--bg);
    padding: var(--s-2) var(--s-4);
    border-radius: var(--r-pill);
    margin: 0 0 var(--s-6);
  }
  .eyebrow .dot { color: var(--accent-lime); animation: pulse 1.5s ease-in-out infinite; }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .eyebrow-dark {
    background: transparent;
    color: var(--muted);
    border: 1px solid color-mix(in srgb, var(--ink) 15%, transparent);
    padding: var(--s-1) var(--s-3);
    font-size: 0.8125rem;
  }
  .eyebrow-dark .dot { display: none; }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 var(--s-5);
    max-width: 18ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent-orange);
    font-family: var(--font-display);
    font-weight: 700;
  }
  .hero-title .hl {
    background: var(--accent-lime);
    padding: 0 0.15em;
    border-radius: 0.1em;
    font-style: italic;
    box-decoration-break: clone;
  }

  .hero-sub {
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.6;
    max-width: 60ch;
    color: var(--ink-soft);
    margin: 0 0 var(--s-6);
  }

  .hero-cta { display: flex; gap: var(--s-3); flex-wrap: wrap; }
  .btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 2px solid var(--ink);
  }
  .btn-ghost:hover { background: var(--ink); color: var(--bg); }

  /* SECTIONS */
  .work, .more-work, .also-building {
    padding: var(--s-9) 0;
  }
  .section-head {
    margin-bottom: var(--s-7);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-3);
  }
  .section-head-center {
    align-items: center;
    text-align: center;
  }
  .section-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    margin: 0;
  }
  .section-title em {
    font-style: italic;
    color: var(--accent-orange);
  }

  /* FEATURED GRID */
  .featured-grid {
    display: grid;
    gap: var(--s-6);
  }
  .feature-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6);
    align-items: center;
    padding: var(--s-7);
    border-radius: var(--r-lg);
    background: var(--bg-alt);
    transition: transform 0.4s var(--ease), background 0.4s var(--ease);
    overflow: hidden;
  }
  .feature-card:hover { transform: translateY(-6px); }
  .feature-card.accent-orange:hover { background: #FFE0CC; }
  .feature-card.accent-lime:hover { background: #EAFAB0; }
  .feature-card.accent-blue:hover { background: #DDE3FF; }
  .feature-card.accent-pink:hover { background: #FFD4E5; }
  .feature-card.accent-violet:hover { background: #E2D6FF; }

  .feature-card:nth-child(even) { grid-template-columns: 1fr 1fr; direction: rtl; }
  .feature-card:nth-child(even) > * { direction: ltr; }

  .feature-number {
    position: absolute;
    top: var(--s-5);
    right: var(--s-6);
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    color: var(--ink);
    opacity: 0.12;
  }
  .feature-image {
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--bg);
  }
  .feature-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .feature-card:hover .feature-image img { transform: scale(1.04); }

  .feature-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-bottom: var(--s-3);
  }
  .feature-title {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    margin: 0 0 var(--s-3);
  }
  .feature-summary {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 var(--s-4);
  }
  .feature-cta {
    font-weight: 600;
    color: var(--ink);
    border-bottom: 2px solid var(--accent-orange);
    padding-bottom: 2px;
  }

  @media (max-width: 800px) {
    .feature-card,
    .feature-card:nth-child(even) {
      grid-template-columns: 1fr;
      direction: ltr;
      padding: var(--s-5);
    }
    .feature-number { font-size: 3rem; }
  }

  /* MORE GRID */
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--s-5);
  }
  .mini-card {
    padding: var(--s-5);
    border-radius: var(--r-lg);
    background: var(--bg-alt);
    transition: transform 0.3s var(--ease), background 0.3s var(--ease);
  }
  .mini-card:hover {
    transform: translateY(-4px);
    background: var(--ink);
    color: var(--bg);
  }
  .mini-image {
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    margin-bottom: var(--s-4);
    background: var(--bg);
  }
  .mini-image img { width: 100%; height: 100%; object-fit: cover; }
  .mini-title {
    font-size: 1.5rem;
    margin: 0 0 var(--s-2);
  }
  .mini-tagline {
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.5;
    opacity: 0.8;
  }

  /* ALSO BUILDING */
  .also-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    max-width: 48ch;
  }
  .venture-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6);
    align-items: center;
    max-width: 880px;
    margin: 0 auto;
    padding: var(--s-6);
    border-radius: var(--r-lg);
    background: var(--bg-alt);
    transition: transform 0.3s var(--ease), background 0.3s var(--ease);
  }
  .venture-card:hover {
    transform: translateY(-4px);
    background: color-mix(in srgb, var(--bg-alt) 70%, var(--accent-orange));
  }
  .venture-image {
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--bg);
  }
  .venture-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .venture-card:hover .venture-image img { transform: scale(1.04); }

  .venture-title {
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin: 0 0 var(--s-3);
  }
  .venture-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 var(--s-4);
  }
  .venture-cta {
    font-weight: 600;
    color: var(--ink);
    border-bottom: 2px solid var(--accent-orange);
    padding-bottom: 2px;
  }

  @media (max-width: 720px) {
    .venture-card {
      grid-template-columns: 1fr;
      padding: var(--s-5);
    }
  }

</style>
