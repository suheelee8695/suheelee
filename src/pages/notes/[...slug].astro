---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const all = await getCollection('writing');
  return all.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${entry.data.title} · Suhee Lee`} current="notes" description={entry.data.description}>
  <article class="essay">
    <header class="essay-hero container-narrow">
      <a href="/notes" class="back-link">← Back to notes</a>
      <h1 class="essay-title">{entry.data.title}</h1>
      <p class="essay-date">
        <em><time datetime={entry.data.date.toISOString()}>{fmt(entry.data.date)}</time></em>
      </p>
      {entry.data.tags.length > 0 && (
        <div class="essay-tags">
          {entry.data.tags.map(t => <span class="pill">{t}</span>)}
        </div>
      )}
    </header>

    <div class="essay-body container-narrow">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .essay { padding-top: var(--s-7); padding-bottom: var(--s-9); }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: var(--s-5);
    transition: color 0.2s var(--ease);
  }
  .back-link:hover { color: var(--ink); }

  .essay-title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 var(--s-3);
  }
  .essay-date {
    margin: 0 0 var(--s-4);
    font-size: 0.9375rem;
    color: var(--muted);
  }
  .essay-date em {
    font-style: italic;
    font-family: var(--font-display);
  }
  .essay-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    padding: var(--s-4) 0 0;
    border-top: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .essay-body { padding-top: var(--s-7); }

  /* Pull-quote treatment for blockquotes inside essays */
  .essay-body :global(.prose blockquote) {
    margin: var(--s-7) 0;
    padding: var(--s-2) 0 var(--s-2) var(--s-5);
    border-left: 4px solid var(--accent-orange);
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.4vw, 1.75rem);
    line-height: 1.35;
    font-style: italic;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .essay-body :global(.prose blockquote p) {
    margin: 0;
  }
</style>
